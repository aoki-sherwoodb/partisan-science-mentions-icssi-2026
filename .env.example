# GCP project that is billed for BigQuery jobs (you have query access through it)
BILLING_PROJECT=

# Dimensions Analytics dataset (standard public-share location; usually leave as-is)
DIMENSIONS_DATASET=dimensions-ai.data_analytics

# Altmetric mention-level dataset holding `attention_sources` (project.dataset)
# fill once confirmed, e.g. some-project.altmetric
ALTMETRIC_DATASET=

# Anthropic API key for the optional CV-extraction module
ANTHROPIC_API_KEY=

# Cost guardrail: abort (before billing) any query scanning more than this many GiB.
# The Dimensions/Altmetric tables are large linked datasets, so core queries scan
# tens of GiB; 50 lets them run while still catching unpruned 80+ GiB mistakes.
MAX_QUERY_GIB=50.0

# BigQuery on-demand price per TiB scanned (USD), used only for the cost estimate display
BQ_PRICE_PER_TIB=6.25

# Where query results and figures are written
OUTPUT_DIR=output-data
